# ---- Arc Testnet (verified 2026-07-14 against docs.arc.io) ----
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network
ARC_TESTNET_CHAIN_ID=5042002
# Testnet-only key used by Hardhat to deploy contracts. Never use a mainnet key here.
ARC_TESTNET_DEPLOYER_PRIVATE_KEY=

# ---- Circle Developer Platform ----
# console.circle.com -> create an API key + register an entity secret
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=

# ---- Supabase (persistence for obligations, decisions, wallets) ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Public HTTPS endpoint Circle posts webhook events to (ngrok tunnel in local dev)
WEBHOOK_ENDPOINT_URL=

# ---- StableFX ----
# Gated/RFQ product — requires requesting access from a Circle rep, no self-serve
# signup as of 2026-07-14. Leave blank until access is granted; the FX adapter
# interface in packages/shared is designed to be swapped in once credentials exist.
STABLEFX_API_KEY=

# ---- Agent wallets (generated via `npm run setup:wallet`, do not hand-edit) ----
TREASURY_WALLET_ID=
TREASURY_WALLET_ADDRESS=

# ---- Obligation escrow contract ----
# Deployed via `npm run deploy:obligation-escrow -w packages/contracts`. Holds
# the treasury's deposited USDC; the agent settles obligations by calling its
# settle() function rather than doing a bare wallet transfer.
OBLIGATION_ESCROW_ADDRESS=

# ---- Agent decision policy ----
# Floor the agent will not pay below, regardless of due date.
TREASURY_RESERVE_USDC=500
# How many days ahead of the due date the agent is willing to settle early.
AGENT_PAY_AHEAD_WINDOW_DAYS=3

# ---- Nanopayments (x402 rate-oracle consultation, apps/oracle) ----
ORACLE_PORT=4000
# Address that receives the agent's per-request nanopayment. No private key
# needed — Circle Gateway settles directly to this address.
ORACLE_SELLER_ADDRESS=
ORACLE_URL=http://localhost:4000/rate
# Throwaway EOA the agent pays FROM — Circle Gateway payments sign directly
# via viem, so this can't go through the Circle-custodied treasury wallet.
# Needs native gas + USDC on Arc Testnet, plus a one-time Gateway deposit
# (see scripts/deposit-gateway.ts).
AGENT_X402_PRIVATE_KEY=

# ---- Cross-chain liquidity top-up (generated via `npm run setup:liquidity-wallet`) ----
# Circle-custodied wallet on Base Sepolia. When the treasury's Arc balance
# would breach TREASURY_RESERVE_USDC, the agent bridges USDC from here into
# the treasury via CCTP (Bridge Kit) before settling. Leave unset to fall
# back to the old flag-only behavior (request_liquidity is recorded but not
# acted on).
LIQUIDITY_WALLET_ID=
LIQUIDITY_WALLET_ADDRESS=

# ---- Vercel Cron (apps/web/api/cron/evaluate) ----
# Vercel sends `Authorization: Bearer $CRON_SECRET` automatically once this is
# set as a project env var; the route rejects any request that doesn't match.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=
